# Copia este archivo a .env y rellena tus claves. El .env real NO se versiona.
# Lo cargan systemd (EnvironmentFile) y db.py (fallback para runs manuales).

# Proveedor de IA por defecto: claude. Elegible desde la UI (página Búsquedas).
# Anthropic (Claude) — proveedor por defecto de resúmenes de empresas y CV + IA.
ANTHROPIC_API_KEY=tu-api-key-de-anthropic
# Opcional: fijar otro modelo de Claude (por defecto claude-opus-4-8).
# ANTHROPIC_MODEL=claude-opus-4-8

# Google AI Studio (Gemini) — proveedor alternativo (gratis).
GEMINI_API_KEY=tu-api-key-de-google-ai-studio
# Opcional: fijar otro modelo de Gemini (por defecto gemini-3.5-flash).
# GEMINI_MODEL=gemini-3.5-flash-lite

# RapidAPI — fuentes de esta plataforma (p. ej. LinkedIn).
RAPIDAPI_KEY=tu-api-key-de-rapidapi
